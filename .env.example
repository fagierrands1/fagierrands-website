# Supabase Configuration
REACT_APP_SUPABASE_URL=your_supabase_url_here
REACT_APP_SUPABASE_ANON_KEY=your_supabase_anon_key_here

# VAPID Keys for Push Notifications
REACT_APP_VAPID_PUBLIC_KEY=your_vapid_public_key_here

# Mapbox Configuration
REACT_APP_MAPBOX_TOKEN=your_mapbox_public_token_here
REACT_APP_MAPBOX_SECRET_TOKEN=your_mapbox_secret_token_here

# Production Frontend URL
REACT_APP_FRONTEND_URL=https://your-frontend-domain.com

# Production API URL
REACT_APP_API_BASE_URL=https://your-backend-domain.com/api
